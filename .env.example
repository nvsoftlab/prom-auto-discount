# Database (SQLite for local dev, change to PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - create at console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES-256-CBC encryption key - generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Cron route secret - generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# Email (SMTP) - for "Forgot Password" emails and sync failure alerts
# Gmail: use App Password (myaccount.google.com/apppasswords), NOT your main password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"

# Admin email for sync failure alerts (defaults to SMTP_USER if not set)
ADMIN_EMAIL=""
